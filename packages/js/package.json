{
  "name": "@svgicons-com/api-client",
  "version": "0.1.0-alpha.0",
  "description": "Typed JavaScript and TypeScript client for the Svg/icons Pro API.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/svgicons-com/api.git",
    "directory": "packages/js"
  },
  "bugs": {
    "url": "https://github.com/svgicons-com/api/issues"
  },
  "homepage": "https://github.com/svgicons-com/api/tree/main/packages/js#readme",
  "keywords": [
    "svgicons",
    "svg",
    "icons",
    "openapi",
    "rest-api",
    "typescript",
    "design-systems"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist', { recursive: true, force: true });\"",
    "prepack": "npm run clean && npm run build",
    "test": "npm run build && node --test test/client.test.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
